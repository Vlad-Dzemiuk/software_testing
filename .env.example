# Copy to ".env" in this folder (docker compose loads it automatically).
# Do not commit ".env" — it is gitignored.
#
# Defaults match docker-compose.yml fallbacks and appsettings.Development.json.
# Override locally or use `dotnet user-secrets set "ConnectionStrings:Default" "..."`
# for the API connection string instead of editing appsettings.

POSTGRES_USER=musicplaylist
